{
  "name": "vlx-flowcraft",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "apps/shared"
  ],
  "scripts": {
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "dev:backend": "npm --prefix apps/backend run dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
